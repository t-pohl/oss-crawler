# Online-Schule Saarland — Anmeldedaten für den Shibboleth-IdP.
# -------------------------------------------------------------
# Empfohlen: leer lassen und
#   oss-crawler --login --auth-only
# nutzen. Das öffnet einen sichtbaren Browser, du loggst dich manuell
# ein (Shibboleth-SSO, ggf. 2FA), und die Session wird in .auth.json
# gespeichert. Spätere Läufe nutzen diese automatisch.
#
# Optional: Username/Passwort für vollautomatischen Headless-Login.
# Klappt zuverlässig, solange der IdP kein CAPTCHA oder MFA verlangt;
# bei Fehlschlag → automatischer Fallback auf den interaktiven Login.
OSS_USERNAME=
OSS_PASSWORD=

# Basis-URL des SAML-SP (normalerweise unverändert lassen).
# Beim Aufruf der Root-URL wird man — falls nicht eingeloggt — zum
# Shibboleth-IdP weitergeleitet.
OSS_BASE_URL=https://meine.online-schule.saarland

# Hostname des Shibboleth-IdP (zur Erkennung von SSO-Redirects).
OSS_IDP_HOST=idp.online-schule.saarland

# Chromium im Headless-Modus beim Auto-Login starten.
# Für --login wird das ignoriert (der interaktive Login öffnet stets
# ein sichtbares Fenster).
HEADLESS=true
